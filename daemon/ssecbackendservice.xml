<service>
	<id>ssecbackendservice.exe</id>
	<name>SSEC-Backend-Service</name>
	<description>Backend module for EasyTimePro-Firebase bridge</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>D:\Backend Module\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>D:\Backend Module\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>SSEC-Backend-Service wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<env name="NODE_ENV" value="production"/>
	<serviceaccount>
		<domain>DESKTOP-G8O81FG</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>D:\Backend Module</workingdirectory>
</service>