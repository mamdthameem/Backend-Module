# EasyTime Pro API Configuration
EASYTIMEPRO_API_URL=http://127.0.0.1:8081
EASYTIMEPRO_USERNAME=admin
EASYTIMEPRO_PASSWORD=your_password

# Server Configuration
PORT=3002
NODE_ENV=development

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
